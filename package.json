{
  "name": "loopify-finalproject",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build:web": "expo export --platform web && node scripts/inject-fonts.js",
    "deploy": "npm run build:web && firebase deploy --only hosting",
    "eas": "npx eas-cli",
    "build:ios": "npx eas-cli build --platform ios",
    "build:ios:preview": "npx eas-cli build --platform ios --profile preview",
    "submit:ios": "npx eas-cli submit --platform ios"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/drawer": "^7.7.8",
    "@react-navigation/native": "^7.1.24",
    "expo": "~54.0.25",
    "expo-blur": "^15.0.8",
    "expo-constants": "~18.0.10",
    "expo-document-picker": "^56.0.4",
    "expo-file-system": "~19.0.19",
    "expo-image-picker": "~17.0.8",
    "expo-linear-gradient": "~15.0.7",
    "expo-linking": "~8.0.9",
    "expo-print": "^56.0.3",
    "expo-router": "~6.0.15",
    "expo-sharing": "^56.0.16",
    "expo-status-bar": "~3.0.8",
    "firebase": "^11.0.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-paper": "^5.12.5",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "^0.21.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "eas-cli": "^16.28.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
